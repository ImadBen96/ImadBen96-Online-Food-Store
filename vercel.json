{
    "version": 2,
    "builds": [
      {
        "src": "/backend/built/server.js",
        "use": "@vercel/node"
      },
      {
        "src": "/backend/dist/frontend/browser/**",
        "use": "@vercel/static"
      }
    ],
    "routes": [
        {
            "handle": "filesystem"
          },
          {
            "src": "/(.*)",
            "dest": "/backend/built/server.js"
          }
    ]
  }
  